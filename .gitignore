# Done with https://www.git-tower.com/free-tools/gitignore and https://www.toptal.com/developers/gitignore

### Universal ###
# Common files that should be ignored in all projects

# Logs
*.log

# Temporary files
*.tmp
*~
*.bak

# Environment (containing secrets, API keys, credentials)
.env
*.env
.env.*

# Local configuration
*.local

