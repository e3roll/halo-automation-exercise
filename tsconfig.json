{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@features/*": ["features/*"]
    },
    "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
